# GraphRAG for Agent Zero - Environment Configuration Example
# ---------------------------------------------------------
# Copy this file to .env and adjust as needed.
# This file is loaded by Agent Zero during startup.

# 1. FEATURE FLAG
# Set to "true" to enable GraphRAG enhancement.
GRAPH_RAG_ENABLED=false

# 2. NEO4J CONNECTION
# Default for Docker-to-Host connectivity (Recommended for Agent Zero):
NEO4J_URI=bolt://host.docker.internal:7687
NEO4J_HTTP_URI=http://host.docker.internal:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Alternative for Local/Native usage (if not in Docker):
# NEO4J_URI=bolt://localhost:7687
# NEO4J_HTTP_URI=http://localhost:7474

# 3. ADVANCED SETTINGS
NEO4J_DATABASE=neo4j
NEO4J_CONNECTION_TIMEOUT_MS=5000
NEO4J_QUERY_TIMEOUT_MS=10000

# Graph search boundaries
GRAPH_EXPAND_MAX_HOPS=2
GRAPH_EXPAND_LIMIT=100
GRAPH_MAX_RESULTS=50
